# Environment variables for production deployment
# Copy this file to .env and update with your actual values

# Database configuration
DB_USER=qgis_admin
DB_PASSWORD=change_this_to_secure_password_123
DB_NAME=gis_platform

# Redis configuration
REDIS_PASSWORD=change_redis_password_456

# Backend security
SECRET_KEY=generate_random_secret_key_here_use_openssl_rand_hex_32

# GeoServer configuration
GEOSERVER_PASSWORD=geoserver_secure_password_789

# Domain configuration (update with your actual domain)
DOMAIN=localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# SSL Configuration (for production)
# SSL_CERT_PATH=/path/to/ssl/cert.pem
# SSL_KEY_PATH=/path/to/ssl/key.pem

# Email for Let's Encrypt notifications
# EMAIL=admin@example.com
