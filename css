    <script>
        // Safe storage helpers
        const safeStorage = {
            getItem: (key) => { try { return localStorage.getItem(key); } catch(e) { return null; } },
            setItem: (key, val) => { try { localStorage.setItem(key, val); } catch(e) { console.warn('Storage blocked'); } },
            getSession: (key) => { try { return sessionStorage.getItem(key); } catch(e) { return null; } },
            setSession: (key, val) => { try { sessionStorage.setItem(key, val); } catch(e) { console.warn('Session storage blocked'); } },
            clearSession: () => { try { sessionStorage.removeItem('prpp_session'); } catch(e) {} }
        };

        const DEFAULT_CONFIG = {
            users: [
                { id: 1, username: 'admin', password: 'admin123', name: 'Администратор', role: 'admin', status: 'active', lastLogin: null },
                { id: 2, username: 'manager', password: 'manager123', name: 'Менеджер', role: 'user', status: 'active', lastLogin: null },
                { id: 3, username: 'analyst', password: 'analyst123', name: 'Аналитик', role: 'user', status: 'inactive', lastLogin: null }
            ],
            cards: [
                { id: 1, icon: '🗺️', title: 'Карта развития парковочного пространства', desc: 'Интерактивная карта с визуализацией текущего состояния и планов развития парковочной инфраструктуры города.', url: 'https://карта.прпп.рф', displayUrl: 'карта.прпп.рф', active: true },
                { id: 2, icon: '🤖', title: 'Анализ проектной документации', desc: 'ИИ-система для автоматического анализа и проверки проектной документации с использованием машинного обучения.', url: 'https://ии.прпп.рф', displayUrl: 'ии.прпп.рф', active: true }
            ],
            welcomeText: 'Выберите нужный раздел для работы с системой',
            systemName: 'ПРПП',
            systemTitle: 'ПРПП — Парковочное пространство',
            logs: []
        };

        let config;
        let currentUser = null;
        let currentPage = 'auth';

        function loadConfig() {
            const saved = safeStorage.getItem('prpp_config');
            config = saved ? JSON.parse(saved) : JSON.parse(JSON.stringify(DEFAULT_CONFIG));
            for (const key in DEFAULT_CONFIG) {
                if (!(key in config)) config[key] = DEFAULT_CONFIG[key];
            }
        }

        function saveConfig() {
            safeStorage.setItem('prpp_config', JSON.stringify(config));
        }

        function addLog(action, type = 'blue') {
            config.logs.unshift({ action, type, time: new Date().toLocaleString('ru-RU') });
            if (config.logs.length > 50) config.logs = config.logs.slice(0, 50);
            saveConfig();
        }

        function hideLoader() {
            const el = document.getElementById('pageLoader');
            if (el) el.classList.add('hidden');
        }

        function init() {
            try {
                loadConfig();
                const session = safeStorage.getSession('prpp_session');
                if (session) {
                    currentUser = JSON.parse(session);
                    updateDashboard();
                    navigateTo('dashboard');
                } else {
                    navigateTo('auth');
                }
                initParticles();
            } catch (err) {
                console.error('Init error:', err);
            } finally {
                hideLoader();
            }
        }

        // Guarantee loader hides
        window.addEventListener('load', () => setTimeout(hideLoader, 600));
        window.addEventListener('DOMContentLoaded', () => setTimeout(hideLoader, 800));

        function navigateTo(page) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            currentPage = page;
            if (page === 'auth') document.getElementById('authPage')?.classList.add('active');
            else if (page === 'dashboard') {
                document.getElementById('dashboardPage')?.classList.add('active');
                updateDashboard();
            } else if (page === 'admin') {
                if (!currentUser || currentUser.role !== 'admin') {
                    showToast('Доступ только для администраторов', 'error');
                    return;
                }
                document.getElementById('adminPage')?.classList.add('active');
                updateAdminPanel();
            }
        }

        function handleLogin(e) {
            e.preventDefault();
            const username = document.getElementById('loginUsername').value.trim();
            const password = document.getElementById('loginPassword').value;
            const errorEl = document.getElementById('authError');
            const btn = document.getElementById('loginBtn');

            btn.textContent = 'Вход...';
            btn.disabled = true;

            setTimeout(() => {
                const user = config.users.find(u => u.username === username && u.password === password);
                if (user) {
                    if (user.status === 'inactive') {
                        errorEl.classList.add('show');
                        document.getElementById('authErrorText').textContent = 'Учётная запись заблокирована';
                        btn.textContent = 'Войти'; btn.disabled = false; return;
                    }
                    currentUser = user;
                    user.lastLogin = new Date().toLocaleString('ru-RU');
                    saveConfig();
                    safeStorage.setSession('prpp_session', JSON.stringify(user));
                    addLog(`Вход пользователя <strong>${user.name}</strong>`, 'green');
                    errorEl.classList.remove('show');
                    navigateTo('dashboard');
                    showToast(`Добро пожаловать, ${user.name}!`);
                } else {
                    errorEl.classList.add('show');
                    document.getElementById('authErrorText').textContent = 'Неверный логин или пароль';
                    addLog(`Попытка входа: ${username} (неудачная)`, 'orange');
                }
                btn.textContent = 'Войти'; btn.disabled = false;
            }, 500);
        }

        function handleLogout() {
            if (currentUser) addLog(`Выход пользователя <strong>${currentUser.name}</strong>`, 'purple');
            currentUser = null;
            safeStorage.clearSession();
            document.getElementById('loginUsername').value = '';
            document.getElementById('loginPassword').value = '';
            document.getElementById('authError').classList.remove('show');
            navigateTo('auth');
            showToast('Вы вышли из системы');
        }

        function updateDashboard() {
            if (!currentUser) return;
            const initials = currentUser.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
            ['dashAvatar', 'adminAvatar'].forEach(id => { const el = document.getElementById(id); if(el) el.textContent = initials; });
            ['dashUsername', 'adminUsername'].forEach(id => { const el = document.getElementById(id); if(el) el.textContent = currentUser.name; });
            
            const wt = document.getElementById('welcomeText'); if(wt) wt.textContent = config.welcomeText;

            config.cards.forEach((card, i) => {
                const num = i + 1;
                [`card${num}Icon`, `card${num}Title`, `card${num}Desc`, `card${num}Url`].forEach(id => {
                    const el = document.getElementById(id); if(el) el.textContent = card[id.replace(`card${num}`, '').toLowerCase()];
                });
                const el = document.getElementById(`card${num}`);
                if(el) {
                    el.href = card.url;
                    el.style.opacity = card.active ? '1' : '0.4';
                    el.style.pointerEvents = card.active ? 'auto' : 'none';
                }
            });
        }

        function handleCardClick(index) {
            if (!config.cards[index].active) {
                showToast('Раздел временно недоступен', 'error');
                return false;
            }
            return true;
        }

        function updateAdminPanel() {
            renderUsersTable();
            renderLogs();
            loadCardSettings();
            updateStats();
        }

        function switchAdminTab(tabName, btnEl) {
            document.querySelectorAll('.admin-tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.admin-nav-item').forEach(b => b.classList.remove('active'));
            const tab = document.getElementById(`tab-${tabName}`);
            if(tab) tab.classList.add('active');
            if(btnEl) btnEl.classList.add('active');
        }

        function updateStats() {
            document.getElementById('statUsers').textContent = config.users.length;
            document.getElementById('statActiveCards').textContent = config.cards.filter(c => c.active).length;
            if (currentUser?.lastLogin) document.getElementById('statLastLogin').textContent = currentUser.lastLogin;
        }

        function loadCardSettings() {
            config.cards.forEach((card, i) => {
                const num = i + 1;
                [`adminCard${num}Icon`, `adminCard${num}Url`, `adminCard${num}Title`, `adminCard${num}Desc`].forEach(id => {
                    const el = document.getElementById(id);
                    if(el) el.value = card[id.replace('admin', '').replace(num, '').toLowerCase()];
                });
            });
            ['adminWelcomeText', 'systemName', 'systemTitle'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.value = config[id.replace('admin', '').toLowerCase()];
            });
        }

        function saveCardSettings(num) {
            const idx = num - 1;
            config.cards[idx].icon = document.getElementById(`adminCard${num}Icon`).value;
            config.cards[idx].url = document.getElementById(`adminCard${num}Url`).value;
            config.cards[idx].title = document.getElementById(`adminCard${num}Title`).value;
            config.cards[idx].desc = document.getElementById(`adminCard${num}Desc`).value;
            saveConfig();
            addLog(`Обновлён <strong>блок ${num}</strong>`, 'blue');
            showToast(`Блок ${num} обновлён`);
            updateDashboard();
        }

        function saveWelcomeText() {
            config.welcomeText = document.getElementById('adminWelcomeText').value;
            saveConfig();
            addLog('Обновлён <strong>приветственный текст</strong>', 'blue');
            showToast('Текст обновлён');
            updateDashboard();
        }

        function saveSystemSettings() {
            config.systemName = document.getElementById('systemName').value;
            config.systemTitle = document.getElementById('systemTitle').value;
            document.title = config.systemTitle;
            saveConfig();
            addLog('Обновлены <strong>системные настройки</strong>', 'blue');
            showToast('Настройки сохранены');
        }

        function renderUsersTable() {
            const tbody = document.getElementById('usersTableBody');
            if(!tbody) return;
            const colors = ['var(--gradient-blue)', 'var(--gradient-purple)', 'var(--gradient-green)'];
            tbody.innerHTML = config.users.map(u => {
                const initials = u.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
                const color = colors[u.id % colors.length];
                const isAdmin = u.role === 'admin';
                const isMe = currentUser && currentUser.id === u.id;
                return `<tr>
                    <td><div class="user-badge"><div class="user-badge-avatar" style="background:${color}">${initials}</div><div><div style="font-weight:500;">${u.name}</div><div style="font-size:0.8rem;color:var(--text-muted);">@${u.username}</div></div></div></td>
                    <td><span class="role-badge ${isAdmin ? 'admin-role' : ''}">${isAdmin ? 'Админ' : 'Пользователь'}</span></td>
                    <td><span class="status-badge ${u.status === 'active' ? 'status-active' : 'status-inactive'}">${u.status === 'active' ? 'Активен' : 'Заблокирован'}</span></td>
                    <td style="font-size:0.85rem;color:var(--text-secondary);">${u.lastLogin || '—'}</td>
                    <td>${!isMe ? `<button class="btn btn-outline btn-sm" style="padding:6px 12px;font-size:0.78rem;" onclick="toggleUserStatus(${u.id})">${u.status === 'active' ? '🔒' : '🔓'}</button> <button class="btn btn-danger btn-sm" style="padding:6px 12px;font-size:0.78rem;" onclick="deleteUser(${u.id})">🗑️</button>` : '<span style="font-size:0.8rem;color:var(--text-muted);">Это вы</span>'}</td>
                </tr>`;
            }).join('');
        }

        function toggleUserStatus(userId) {
            const user = config.users.find(u => u.id === userId);
            if (user) {
                user.status = user.status === 'active' ? 'inactive' : 'active';
                saveConfig();
                renderUsersTable(); updateStats();
                addLog(`Статус <strong>${user.name}</strong> изменён на "${user.status}"`, 'orange');
                showToast(`Статус ${user.name} обновлён`);
            }
        }

        function deleteUser(userId) {
            if (currentUser?.id === userId) return showToast('Нельзя удалить себя', 'error');
            const user = config.users.find(u => u.id === userId);
            if (user && confirm(`Удалить пользователя ${user.name}?`)) {
                config.users = config.users.filter(u => u.id !== userId);
                saveConfig(); renderUsersTable(); updateStats();
                addLog(`Пользователь <strong>${user.name}</strong> удалён`, 'orange');
                showToast('Пользователь удалён');
            }
        }

        function openAddUserModal() { document.getElementById('addUserModal')?.classList.add('show'); }
        function closeAddUserModal() {
            document.getElementById('addUserModal')?.classList.remove('show');
            ['newUsername', 'newPassword', 'newFullname'].forEach(id => { const el = document.getElementById(id); if(el) el.value = ''; });
        }

        function addUser(e) {
            e.preventDefault();
            const username = document.getElementById('newUsername').value.trim();
            const password = document.getElementById('newPassword').value;
            const name = document.getElementById('newFullname').value.trim();
            const role = document.getElementById('newRole').value;
            if (config.users.find(u => u.username === username)) return showToast('Пользователь уже существует', 'error');
            config.users.push({ id: Date.now(), username, password, name, role, status: 'active', lastLogin: null });
            saveConfig(); renderUsersTable(); updateStats(); closeAddUserModal();
            addLog(`Создан пользователь <strong>${name}</strong>`, 'green');
            showToast(`Пользователь ${name} создан`);
        }

        function renderLogs() {
            const list = document.getElementById('activityList');
            if(!list) return;
            if (config.logs.length === 0) { list.innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;">Журнал пуст</p>'; return; }
            list.innerHTML = config.logs.map(log => `<div class="activity-item"><div class="activity-dot ${log.type}"></div><div><div class="activity-text">${log.action}</div><div class="activity-time">${log.time}</div></div></div>`).join('');
        }

        function clearLogs() { config.logs = []; saveConfig(); renderLogs(); showToast('Журнал очищен'); }
        function toggleSetting(wrap) { wrap.querySelector('.toggle')?.classList.toggle('active'); }
        function resetAllSettings() {
            if (confirm('Сбросить все настройки к значениям по умолчанию?')) {
                config = JSON.parse(JSON.stringify(DEFAULT_CONFIG)); saveConfig(); loadCardSettings(); updateDashboard(); updateAdminPanel();
                addLog('Все настройки <strong>сброшены</strong>', 'orange'); showToast('Настройки сброшены');
            }
        }

        function exportConfig() {
            try {
                const data = JSON.stringify(config, null, 2);
                const blob = new Blob([data], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a'); a.href = url; a.download = 'prpp-config.json'; a.click();
                URL.revokeObjectURL(url);
                showToast('Конфигурация экспортирована');
            } catch(e) { showToast('Ошибка экспорта', 'error'); }
        }

        function showToast(text, type = 'success') {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            document.getElementById('toastText').textContent = text;
            toast.className = `toast ${type} show`;
            icon.textContent = type === 'success' ? '✅' : '❌';
            setTimeout(() => toast?.classList.remove('show'), 3500);
        }

        function initParticles() {
            const canvas = document.getElementById('particles-canvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let particles = [];
            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            resize(); window.addEventListener('resize', resize);
            for (let i = 0; i < 50; i++) {
                particles.push({ x: Math.random() * canvas.width, y: Math.random() * canvas.height, size: Math.random() * 1.5 + 0.5, speedX: (Math.random() - 0.5) * 0.3, speedY: (Math.random() - 0.5) * 0.3, opacity: Math.random() * 0.4 + 0.1 });
            }
            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles.forEach(p => {
                    p.x += p.speedX; p.y += p.speedY;
                    if (p.x < 0 || p.x > canvas.width) p.speedX *= -1;
                    if (p.y < 0 || p.y > canvas.height) p.speedY *= -1;
                    ctx.beginPath(); ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(79, 172, 254, ${p.opacity})`; ctx.fill();
                });
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx*dx + dy*dy);
                        if (dist < 100) {
                            ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y); ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.strokeStyle = `rgba(79, 172, 254, ${0.06 * (1 - dist/100)})`; ctx.lineWidth = 0.5; ctx.stroke();
                        }
                    }
                }
                requestAnimationFrame(animate);
            }
            animate();
        }

        window.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>

